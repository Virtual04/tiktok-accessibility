{
  "manifest_version": 3,
  "name": "TikTok Akadálymentesítő",
  "version": "0.3.0",
  "description": "Billentyűparancsok, hangvezérlés és képernyőolvasó-támogatás (NVDA) a tiktok.com webhelyhez.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tiktok-akadalymentesito@pappalfonz.gmail.com",
      "strict_min_version": "115.0"
    }
  }
}
